toggleStroke.Thickness = 2
toggleStroke.Color = Color3.fromRGB(100, 100, 100)
toggleStroke.Parent = toggleButton

-- Make frame draggable
local dragging = false
local dragInput
local dragStart
local startPos

mainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

-- Variables
local forceRarestEnabled = false
local modeActiveText = "Mode: ON (Rarest Pet Forced)"
local modeInactiveText = "Mode: OFF"

-- Toggle function
local function toggleMode()
    forceRarestEnabled = not forceRarestEnabled
    
    if forceRarestEnabled then
        toggleButton.Text = "Force Rarest Pet: ON"
        toggleButton.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        statusLabel.Text = modeActiveText
        statusLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
        print("Force Rarest Pet Mode ACTIVATED")
    else
        toggleButton.Text = "Force Rarest Pet: OFF"
        toggleButton.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        statusLabel.Text = modeInactiveText
        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
        print("Force Rarest Pet Mode DEACTIVATED")
    end
end

toggleButton.MouseButton1Click:Connect(toggleMode)

-- INSERT key to toggle GUI visibility
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.Insert then
        mainFrame.Visible = not mainFrame.Visible
    end
end)

-- Initial state
mainFrame.Visible = true
statusLabel.Text = modeInactiveText

print("Force Rarest Pet GUI loaded! Press INSERT to toggle menu.")

